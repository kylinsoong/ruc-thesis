flowchart TD
    subgraph A[数据源]
        A1[“结构化数据<br>（交易、客户）”]
        A2[“非结构化数据<br>（合同、舆情、客服录音）”]
    end

    subgraph B[数据层]
        B1[“实时数据流<br>处理平台”]
        B2[“大数据平台<br>（数据湖/仓）”]
        B3[“特征工程平台”]
    end

    subgraph C[模型与决策层]
        C1[“传统模型区<br>（规则引擎、评分卡、GBDT等）”]
        C2[“LLM与RAG增强区”]
    end

    C1 & C2 --> C3[“决策引擎<br>（策略编排与调度）”]

    subgraph D[应用层]
        D1[“实时风险拦截”]
        D2[“信贷审批”]
        D3[“案件调查与审核”]
        D4[“风险报告与监管报送”]
    end

    A --> B
    B --> C
    C3 --> D